rules_version = '2';

// The app only accesses Storage via the Admin SDK (see src/lib/firebase-admin.ts),
// which always bypasses these rules. This file exists so `firebase deploy` and the
// local Storage emulator have something to enforce for any future client-side access.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
